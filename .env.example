# certguard configuration — copy to .env and fill in values
CERTGUARD_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/certguard
CERTGUARD_SECRET_KEY=  # REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CERTGUARD_DEBUG=false

# Docker Compose postgres settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=  # REQUIRED — set a strong password
POSTGRES_DB=certguard
